# Example why configuration.
# Global config lives at $XDG_CONFIG_HOME/why/why.toml (or ~/.config/why/why.toml).
# Repo-local overrides live at why.local.toml in your repository root.
#
# All values below are optional. Missing values fall back to built-in defaults.
# Repo-local config only needs to include overrides; it does not need to duplicate
# global settings or credentials.
# Keywords are matched case-insensitively against commit messages, diff context,
# and nearby source comments/markers when heuristic risk is computed.

[risk]
# Fallback risk level when commit history and built-in/custom keywords do not
# imply more urgency. Accepted values are LOW, MEDIUM, or HIGH.
default_level = "LOW"

[risk.keywords]
# Domain-specific HIGH-risk keywords layered on top of the built-in heuristic vocabulary.
# Use this for terms where deletion or refactoring should trigger extra caution.
high = [
  "pci",
  "reconciliation",
  "ledger",
]

# Domain-specific MEDIUM-risk keywords for migrations, integrations, or
# compatibility-sensitive concepts that deserve review before changes land.
medium = [
  "terraform",
  "webhook",
  "idempotency",
]

[git]
# Maximum number of commits to keep in ranked archaeology output after scoring.
max_commits = 8

# Recent commits inside this window receive a relevance boost.
recency_window_days = 90

# Commits touching at least this many files are more likely to be treated as mechanical.
mechanical_threshold_files = 50

# Maximum number of recent commits to inspect when computing file coupling.
coupling_scan_commits = 500

# Minimum shared-history ratio required to report another file as coupled.
# Lower values surface weaker relationships; higher values keep only stronger co-change signals.
coupling_ratio_threshold = 0.30

[cache]
# Maximum number of cached why reports retained in `.why/cache.json` before the
# oldest entries are evicted. Set to 0 to disable query-result retention.
max_entries = 500

[llm]
# LLM provider: "anthropic", "openai", "zai", or "custom".
# Defaults to "anthropic" if not specified.
# provider = "anthropic"

# Model name to use. Falls back to the provider default for built-in providers.
# model = "claude-haiku-4-5-20251001"

# Base URL for the provider API. Built-in providers use a default when omitted.
# Anthropic-compatible providers should use the full `/v1/messages` endpoint.
# Custom providers should set this explicitly.
# base_url = "https://api.anthropic.com/v1/messages"

# Auth token stored in config. Prefer provider env vars when possible:
# ANTHROPIC_API_KEY, OPENAI_API_KEY, ZAI_API_KEY, CUSTOM_API_KEY.
# Environment variables win when both are present; blank values are ignored.
# auth_token = "your_provider_token_here"

# Number of retry attempts for LLM requests. Defaults to 3.
# retries = 3

# Maximum output tokens. Defaults to 500.
# max_tokens = 500

# Request timeout in seconds. Defaults to 30.
# timeout = 30

[github]
# Git remote name used to infer the repository when GitHub enrichment is enabled.
remote = "origin"

# Prefer GITHUB_TOKEN in the environment; this fallback is optional.
# Environment variables win when both are present, and blank values are ignored.
# Security note: storing tokens in why.local.toml or why.toml is less safe than using environment
# variables because the file can be committed, copied, or left readable on disk.
# Only use the fallback for local development in a trusted repository.
# token = "your_github_token_here"
